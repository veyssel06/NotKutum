@model KisiselNotYonetimSistemi.Entity.Concrete.Note
@{
    ViewData["Title"] = "Not Düzenle";
}

<style>
    .form-card {
        border: none;
        border-radius: 20px;
        max-width: 680px;
        width: 100%;
    }

        .form-card .card-body {
            padding: 36px;
        }

    .page-title {
        font-weight: 700;
        font-size: 1.2rem;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .page-title .title-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, #f59e0b, #f97316);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1rem;
            flex-shrink: 0;
        }

    .form-label {
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 6px;
    }

    .form-control, .form-select {
        border-radius: 10px;
        border: 1.5px solid #e5e7eb;
        padding: 11px 14px;
        font-size: 0.92rem;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

        .form-control:focus, .form-select:focus {
            border-color: #f59e0b;
            box-shadow: 0 0 0 3px rgba(245,158,11,0.15);
        }

    textarea.form-control {
        resize: vertical;
        min-height: 160px;
    }

    .btn-update {
        background: linear-gradient(135deg, #f59e0b, #f97316);
        border: none;
        border-radius: 10px;
        padding: 11px 28px;
        font-weight: 600;
        font-size: 0.92rem;
        color: white;
        transition: opacity 0.2s, transform 0.1s;
    }

        .btn-update:hover {
            opacity: 0.9;
            color: white;
            transform: translateY(-1px);
        }

    .btn-cancel {
        border-radius: 10px;
        padding: 11px 24px;
        font-weight: 600;
        font-size: 0.92rem;
        border: 1.5px solid #e5e7eb;
        background: transparent;
        transition: background 0.15s;
        text-decoration: none;
        color: inherit;
        display: inline-flex;
        align-items: center;
    }

        .btn-cancel:hover {
            background: #f9fafb;
        }

    /* Renk seçici */
    .color-picker-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .color-option {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 3px solid transparent;
        cursor: pointer;
        transition: transform 0.15s, border-color 0.15s;
    }

        .color-option:hover {
            transform: scale(1.15);
        }

        .color-option.selected {
            border-color: #f59e0b;
            transform: scale(1.15);
        }

    /* Karakter sayacı */
    .char-counter {
        font-size: 0.78rem;
        text-align: right;
        margin-top: 4px;
        transition: color 0.2s;
    }

        .char-counter.ok {
            color: #10b981;
        }

        .char-counter.warn {
            color: #f59e0b;
        }

        .char-counter.danger {
            color: #ef4444;
        }

    @@media (max-width: 768px) {
        .form-card .card-body {
            padding: 20px;
        }

        .btn-update, .btn-cancel {
            width: 100%;
            justify-content: center;
        }

        .d-flex.gap-3 {
            flex-direction: column;
        }
    }
</style>

<div class="card form-card shadow-sm">
    <div class="card-body">
        <div class="page-title">
            <div class="title-icon"><i class="bi bi-pencil"></i></div>
            Not Düzenle
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger border-0 rounded-3 mb-4" style="background:#fef2f2;color:#dc2626;font-size:0.88rem;">
                <i class="bi bi-exclamation-circle me-2"></i>@ViewBag.Error
            </div>
        }

        <form method="post">
            <input type="hidden" name="NoteID" value="@Model.NoteID" />
            <input type="hidden" name="CreatedDate" value="@Model.CreatedDate" />
            <div class="mb-3">
                <label class="form-label">Başlık</label>
                <input type="text" name="Title" class="form-control" value="@Model.Title"
                       placeholder="Not başlığı girin" required />
            </div>
            <div class="mb-3">
                <label class="form-label">İçerik</label>
                <textarea name="Content" id="contentArea" class="form-control"
                          placeholder="Not içeriğini buraya yazın...">@Model.Content</textarea>
                <div class="char-counter ok" id="charCounter">0 karakter</div>
            </div>
            <div class="mb-3">
                <label class="form-label">Kategori</label>
                <select name="CategoryID" class="form-select">
                    <option value="">-- Kategori Seç --</option>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        if (cat.CategoryID == Model.CategoryID)
                        {
                            <option value="@cat.CategoryID" selected>@cat.CategoryName</option>
                        }
                        else
                        {
                            <option value="@cat.CategoryID">@cat.CategoryName</option>
                        }
                    }
                </select>
            </div>
            <div class="mb-4">
                <label class="form-label">Not Rengi</label>
                <div class="color-picker-row">
                    @foreach (var color in new[] { "#ffffff", "#fef9c3", "#dcfce7", "#dbeafe", "#fce7f3", "#ede9fe", "#ffedd5", "#f1f5f9" })
                    {
                        <div class="color-option @(color == (Model.Color ?? "#ffffff") ? "selected" : "")"
                             style="background:@color;"
                             onclick="selectColor('@color', this)"
                             title="@color">
                        </div>
                    }
                </div>
                <input type="hidden" name="Color" id="colorInput" value="@(Model.Color ?? "#ffffff")" />
            </div>
            <div class="d-flex gap-3">
                <button type="submit" class="btn-update">
                    <i class="bi bi-check-lg me-1"></i> Güncelle
                </button>
                <a asp-action="Index" class="btn-cancel">İptal</a>
            </div>
        </form>
    </div>
</div>

<script>
    // Karakter sayacı — mevcut içeriği say
    const contentArea = document.getElementById('contentArea');
    const charCounter = document.getElementById('charCounter');

    function updateCounter() {
        const len = contentArea.value.length;
        charCounter.textContent = len + ' karakter';
        charCounter.className = 'char-counter';
        if (len < 500) charCounter.classList.add('ok');
        else if (len < 1000) charCounter.classList.add('warn');
        else charCounter.classList.add('danger');
    }

    contentArea.addEventListener('input', updateCounter);
    updateCounter(); // sayfa açılışında mevcut karakteri göster

    // Renk seçici
    function selectColor(color, el) {
        document.querySelectorAll('.color-option').forEach(c => c.classList.remove('selected'));
        el.classList.add('selected');
        document.getElementById('colorInput').value = color;
    }
</script>