@model List<KisiselNotYonetimSistemi.Entity.Concrete.Note>
@{
    ViewData["Title"] = "Arşiv";
}

<style>
    .note-card { border:none; border-radius:16px; transition:transform 0.2s,box-shadow 0.2s; }
    .note-card:hover { transform:translateY(-4px); box-shadow:0 12px 32px rgba(0,0,0,0.1)!important; }
    .note-title { font-weight:700; font-size:1rem; margin-bottom:8px; }
    .note-preview { opacity:0.7; font-size:0.85rem; line-height:1.6; margin-bottom:16px; }
    .note-date { font-size:0.78rem; opacity:0.6; }
    .note-actions {
        display:flex;
        flex-wrap:wrap;
        gap:6px;
        margin-top:16px;
        padding-top:16px;
        border-top:1px solid rgba(128,128,128,0.15);
    }
    .btn-action {
        border-radius:8px;
        padding:6px 10px;
        font-size:0.8rem;
        font-weight:500;
        border:none;
        transition:opacity 0.15s;
        text-decoration:none;
        display:inline-flex;
        align-items:center;
        white-space:nowrap;
    }
    .btn-action:hover { opacity:0.85; }
    .btn-restore { background:rgba(16,185,129,0.1); color:#10b981; }
    .btn-delete { background:rgba(239,68,68,0.1); color:#ef4444; }
    .note-accent { height:4px; border-radius:16px 16px 0 0; }
    .page-header {
        display:flex;
        justify-content:space-between;
        align-items:center;
        margin-bottom:28px;
        gap:12px;
    }
    .page-header h5 { font-weight:700; font-size:1.3rem; margin:0; }
    .note-count { background:rgba(16,185,129,0.1); color:#10b981; border-radius:20px; padding:2px 12px; font-size:0.82rem; font-weight:600; margin-left:10px; }
    .empty-state { text-align:center; padding:80px 0; color:#9ca3af; }
    .empty-state i { font-size:3.5rem; margin-bottom:16px; display:block; color:#d1d5db; }

    @@media (max-width: 768px) {
        .page-header h5 { font-size:1.1rem; }
        .card-body { padding:16px !important; }
        .btn-action { padding:5px 8px; font-size:0.75rem; }
    }
</style>

<div class="page-header">
    <h5>
        Arşiv
        @if (Model != null && Model.Count > 0)
        {
            <span class="note-count">@Model.Count not</span>
        }
    </h5>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill">
        <i class="bi bi-arrow-left me-1"></i> Notlarıma Dön
    </a>
</div>

@if (Model != null && Model.Count > 0)
{
    <div class="row g-4">
        @{
            var colors = new[] { "#6366f1","#10b981","#f59e0b","#ef4444","#8b5cf6","#06b6d4" };
            int i = 0;
        }
        @foreach (var note in Model)
        {
            var color = colors[i % colors.Length]; i++;
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="card note-card shadow-sm h-100">
                    <div class="note-accent" style="background:@color"></div>
                    <div class="card-body p-4">
                        <div class="note-title">@note.Title</div>
                        <div class="note-preview">
                            @(note.Content?.Length > 100 ? note.Content.Substring(0,100)+"..." : note.Content)
                        </div>
                        <div class="note-date">
                            <i class="bi bi-calendar3 me-1"></i>
                            @note.CreatedDate.ToString("dd MMM yyyy")
                        </div>
                        <div class="note-actions">
                            <a asp-action="Restore" asp-route-id="@note.NoteID" class="btn-action btn-restore">
                                <i class="bi bi-arrow-counterclockwise me-1"></i>Geri Yükle
                            </a>
                            <a href="/Note/SoftDelete/@note.NoteID" class="btn-action btn-delete"
                               onclick="event.preventDefault(); showConfirm('Not çöp kutusuna taşınacak.', this.href, 'danger')">
                                <i class="bi bi-trash me-1"></i>Sil
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state">
        <i class="bi bi-archive"></i>
        <p>Arşivde hiç not yok.</p>
    </div>
}
